#!/usr/bin/env bash
# hush — a secret store for AI agents, with one hard rule:
#
#   THE AGENT NEVER SEES THE PLAINTEXT.
#
# A secret value must never reach stdout, argv, logs, or the chat transcript. Every subcommand
# either captures a value WITHOUT printing it (set / mint) or injects it straight into a consumer
# WITHOUT printing it (run / pipe / file). There is deliberately NO `get`, a plain getter is the leak.
#
# The point: stop the "go set THIS env var / paste THIS token into THAT system" dance. Store a
# credential once, then inject it wherever it's needed, without it ever passing through the agent.
#
# Backends (auto-detected), all the OS's own per-user secret store:
#   macOS    -> Keychain (`security`)
#   Linux    -> libsecret (`secret-tool`)
#   Windows  -> DPAPI per-user encrypted store via PowerShell (win/hush-backend.ps1)
# Namespace via HUSH_NS (default: hush) prefixes every item so a human can find them.
# The store itself is the source of truth; `list` enumerates it (no separate index to drift).
#
# NOT a security vault: an agent with shell access can read+write this store. It's structure that
# keeps plaintext out of the transcript, not a lock against a hostile local process.

# never let an inherited trace dump secret values to stderr/transcript.
set +x 2>/dev/null || true
unset BASH_XTRACEFD 2>/dev/null || true
set -uo pipefail

NS="${HUSH_NS:-hush}"
HERE="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

die() { printf 'hush: %s\n' "$1" >&2; exit 1; }

case "$(uname -s 2>/dev/null)" in
  Darwin) BACKEND=mac ;;
  Linux)  BACKEND=linux ;;
  MINGW*|MSYS*|CYGWIN*|Windows_NT) BACKEND=windows ;;
  *) BACKEND=unknown ;;
esac

svc() { printf '%s:%s' "$NS" "$1"; }

# locate the windows backend + translate the path for powershell if needed
ps_backend() {
  local p="$HERE/win/hush-backend.ps1"
  command -v cygpath >/dev/null 2>&1 && p="$(cygpath -w "$p")"
  printf '%s' "$p"
}
# run the windows backend: HUSH_NS in env, verb+name on argv (not secret), value (if any) on stdin.
winps() { HUSH_NS="$NS" powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "$(ps_backend)" "$@"; }

backend_check() {
  case "$BACKEND" in
    mac)     command -v security    >/dev/null 2>&1 || die "the macOS 'security' CLI is required." ;;
    linux)   command -v secret-tool >/dev/null 2>&1 || die "secret-tool (libsecret) required: apt install libsecret-tools / dnf install libsecret." ;;
    windows) command -v powershell.exe >/dev/null 2>&1 || die "powershell.exe required for the windows backend." ;;
    *)       die "no built-in backend for this platform ($(uname -s 2>/dev/null)). Keep the contract (never print, inject-only, no getter) with your OS secret store. (see SKILL.md)" ;;
  esac
}

b_exists() {
  case "$BACKEND" in
    mac)     security find-generic-password -s "$(svc "$1")" >/dev/null 2>&1 ;;
    linux)   [ -n "$(secret-tool lookup hush "$NS" name "$1" 2>/dev/null)" ] ;;
    windows) winps exists "$1" >/dev/null 2>&1 ;;
  esac
}

# store <name> <value> — value is a shell local, never echoed.
b_store() {
  local name="$1" value="$2"
  case "$BACKEND" in
    mac)     security add-generic-password -U -a "$name" -s "$(svc "$name")" -w "$value" >/dev/null 2>&1 \
               || die "keychain store failed for '$name'" ;;
    linux)   printf '%s' "$value" | secret-tool store --label="$(svc "$name")" hush "$NS" name "$name" >/dev/null 2>&1 \
               || die "secret-tool store failed for '$name'" ;;
    windows) printf '%s' "$value" | winps store "$name" >/dev/null 2>&1 \
               || die "windows store failed for '$name'" ;;
  esac
}

# fetch <name> <outvar> — reads value into the named caller variable, never prints it.
b_fetch() {
  local name="$1" __out="$2" __v
  b_exists "$name" || die "no secret named '$name' (try: hush list)"
  case "$BACKEND" in
    mac)     __v="$(security find-generic-password -s "$(svc "$name")" -w 2>/dev/null)" || die "keychain read failed for '$name'" ;;
    linux)   __v="$(secret-tool lookup hush "$NS" name "$name" 2>/dev/null)" || die "secret-tool read failed for '$name'" ;;
    windows) __v="$(winps get "$name" 2>/dev/null)" || die "windows read failed for '$name'" ;;
  esac
  printf -v "$__out" '%s' "$__v"
}

b_delete() {
  case "$BACKEND" in
    mac)     security delete-generic-password -s "$(svc "$1")" >/dev/null 2>&1 ;;
    linux)   secret-tool clear hush "$NS" name "$1" >/dev/null 2>&1 ;;
    windows) winps delete "$1" >/dev/null 2>&1 ;;
  esac
}

# enumerate NAMES from the store (never values). source of truth, no separate index.
b_list() {
  case "$BACKEND" in
    mac)     security dump-keychain 2>/dev/null | sed -n "s/.*\"svce\"<blob>=\"$NS:\(.*\)\"\$/\1/p" | sort -u ;;
    linux)   secret-tool search --all hush "$NS" 2>/dev/null | sed -n 's/^attribute\.name = //p' | sort -u ;;
    windows) winps list 2>/dev/null | sort -u ;;
  esac
}

# read a value WITHOUT echoing it: stdin if piped (scripts/CI), else GUI dialog on mac / silent tty prompt.
prompt_value() {
  local name="$1" __out="$2" __v=""
  if [ ! -t 0 ]; then
    __v="$(cat)"                       # piped in: printf '%s' "$val" | hush set <name>
  elif [ "$BACKEND" = mac ] && command -v osascript >/dev/null 2>&1; then
    __v="$(osascript -e "try
  text returned of (display dialog \"Paste the value for secret: $name\" default answer \"\" with hidden answer with title \"hush set\")
end try" 2>/dev/null)" || true
  else
    printf 'paste value for "%s" (input hidden): ' "$name" >&2
    read -rs __v < /dev/tty || true
    printf '\n' >&2
  fi
  printf -v "$__out" '%s' "$__v"
}

usage() {
  cat >&2 <<'EOF'
hush — a secret store for AI agents. values are never printed.

  hush set  <name>                 store a value you ALREADY hold. interactive hidden prompt, or
                                   pipe it: printf '%s' "$VAL" | hush set <name>. re-run to rotate.
  hush mint <name> [--bytes N] [--force]   (alias: gen)
                                   generate a strong random value (default 32 bytes hex), store it
  hush run  ENVVAR=secret-name [E2=name2 ...] -- <cmd...>
                                   inject secret(s) as env vars, exec <cmd> (value only in the child)
  hush pipe <name> -- <cmd...>     stream the value to <cmd>'s stdin (e.g. wrangler secret put)
  hush file <name> <path>          write the value to a 0600 file (refuses inside a git repo)
  hush list                        list NAMES only, read straight from the store (never values)
  hush rm   <name>                 delete a secret

Rule: a value is never sent to stdout. There is no `get`. Namespace via HUSH_NS (default hush).
If a HUMAN needs to read a value, they do it themselves (the agent never prints it):
  macOS  : Keychain Access, search "hush", open "hush:<name>", Show password.
  linux  : the human runs:  secret-tool lookup hush "$HUSH_NS" name <name>
  windows: the human runs:  powershell -File win/hush-backend.ps1 get <name>   (decrypts for them)
EOF
  exit "${1:-2}"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  set)
    backend_check
    name="${1:-}"; [ -n "$name" ] || usage
    prompt_value "$name" value
    [ -n "${value:-}" ] || die "no value entered (cancelled or empty); nothing stored."
    b_store "$name" "$value"; unset value
    printf 'hush: stored %s (value not shown).\n' "$name"
    ;;
  mint|gen)
    backend_check
    name="${1:-}"; shift || true
    [ -n "${name:-}" ] || usage
    bytes=32; force=0
    while [ $# -gt 0 ]; do case "$1" in
      --bytes) bytes="${2:?--bytes needs a number}"; shift 2;;
      --force) force=1; shift;;
      *) die "mint: unknown arg '$1'";;
    esac; done
    case "$bytes" in ''|*[!0-9]*) die "mint: --bytes must be a positive integer";; esac
    [ "$bytes" -gt 0 ] 2>/dev/null || die "mint: --bytes must be a positive integer"
    if b_exists "$name" && [ "$force" -ne 1 ]; then
      die "'$name' already exists; refusing to overwrite a live key. Use --force to replace."
    fi
    if command -v openssl >/dev/null 2>&1; then
      value="$(openssl rand -hex "$bytes")" || die "openssl failed"
    else
      value="$(head -c "$bytes" /dev/urandom | od -An -tx1 | tr -d ' \n')" || die "no openssl and /dev/urandom failed"
    fi
    b_store "$name" "$value"; unset value
    printf 'hush: minted %s (%d bytes hex, value not shown).\n' "$name" "$bytes"
    ;;
  run)
    backend_check
    vars=(); names=()
    while [ $# -gt 0 ] && [ "$1" != "--" ]; do
      case "$1" in
        *=*) var="${1%%=*}"; nm="${1#*=}"
             case "$var" in ''|[!A-Za-z_]*|*[!A-Za-z0-9_]*) die "run: bad env var name '$var' (must be a valid identifier)";; esac
             vars+=("$var"); names+=("$nm") ;;
        *) die "run: expected ENVVAR=secret-name before --, got '$1'";;
      esac; shift
    done
    [ "${1:-}" = "--" ] || die "run: missing -- before the command"
    shift; [ $# -gt 0 ] || die "run: no command after --"
    # export each secret into THIS process's environment (NOT argv), then exec. environ is owner-only.
    i=0
    while [ "$i" -lt "${#vars[@]}" ]; do
      b_fetch "${names[$i]}" __val          # __val: must NOT collide with b_fetch's internal locals
      export "${vars[$i]}=$__val"; unset __val
      i=$((i + 1))
    done
    exec "$@"
    ;;
  pipe)
    backend_check
    name="${1:-}"; [ -n "$name" ] || usage; shift
    [ "${1:-}" = "--" ] || die "pipe: missing -- before the command"
    shift; [ $# -gt 0 ] || die "pipe: no command after --"
    b_fetch "$name" __val
    printf '%s' "$__val" | "$@"; rc=$?; unset __val; exit $rc
    ;;
  file)
    backend_check
    name="${1:-}"; path="${2:-}"
    { [ -n "$name" ] && [ -n "$path" ]; } || usage
    if git -C "$(dirname "$path")" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      die "refusing to write a secret inside a git repo ($path). Use /tmp or a non-tracked dir."
    fi
    b_fetch "$name" __val
    ( umask 077; rm -f "$path"; printf '%s' "$__val" > "$path" ) || die "write failed: $path"
    chmod 600 "$path" 2>/dev/null || true; unset __val
    printf 'hush: wrote %s to %s (0600, value not shown).\n' "$name" "$path"
    ;;
  list)
    backend_check
    out="$(b_list)"
    [ -n "$out" ] && printf '%s\n' "$out" || printf '(no secrets stored yet)\n'
    ;;
  rm)
    backend_check
    name="${1:-}"; [ -n "$name" ] || usage
    b_delete "$name"
    printf 'hush: removed %s.\n' "$name"
    ;;
  ""|-h|--help|help) usage 0;;
  *) die "unknown subcommand '$cmd' (try: hush help)";;
esac
